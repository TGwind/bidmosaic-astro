---
import { useTranslations, getLocalePath } from '@i18n/utils';
import type { Locale } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<footer class="bg-[var(--bg-dark)] border-t border-white/5">
  <div class="container py-12">
    <div class="flex flex-col items-center text-center gap-6">
      <!-- WeChat QR Code -->
      <div>
        <h4 class="text-sm font-semibold text-[var(--text-primary)] mb-3 uppercase tracking-wider">
          {locale === 'zh' ? '微信联系' : 'WeChat Contact'}
        </h4>
        <div class="bg-white rounded-xl p-3 inline-block">
          <img
            src="/images/个人微信.jpg"
            alt="WeChat QR Code"
            class="w-36 h-36 object-contain"
          />
        </div>
        <p class="text-sm text-[var(--text-secondary)] mt-2">
          {locale === 'zh' ? '扫码添加微信' : 'Scan to add on WeChat'}
        </p>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-8 pt-6 border-t border-white/5 flex justify-center">
      <p class="text-xs text-[var(--text-muted)]">{t.footer.copyright}</p>
    </div>
  </div>
</footer>
