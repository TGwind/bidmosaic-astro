---
import { useTranslations, getLocalePath } from '@i18n/utils';
import type { Locale } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<footer class="bg-[var(--bg-dark)] border-t border-white/5">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Company Address -->
      <div>
        <h4 class="text-sm font-semibold text-[var(--text-primary)] mb-4 uppercase tracking-wider">{t.footer.address_title}</h4>
        <div class="space-y-4">
          <div>
            <p class="text-sm text-[var(--text-primary)] font-medium">{t.footer.company_sz_name}</p>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed mt-1">{t.footer.company_sz_address}</p>
          </div>
          <div>
            <p class="text-sm text-[var(--text-primary)] font-medium">{t.footer.company_hk_name}</p>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed mt-1">{t.footer.company_hk_address}</p>
          </div>
        </div>
      </div>

      <!-- Contact Us -->
      <div>
        <h4 class="text-sm font-semibold text-[var(--text-primary)] mb-4 uppercase tracking-wider">{t.footer.contact_title}</h4>
        <ul class="space-y-3">
          <li><span class="text-sm text-[var(--text-secondary)]">Phone: {t.footer.phone}</span></li>
          <li><a href="mailto:contact@bidmosaic.com" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">contact@bidmosaic.com</a></li>
        </ul>
        <!-- Social Icons -->
        <div class="flex gap-3 mt-6">
          <a href="#" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-[#1877F2] hover:bg-[#1669d5] flex items-center justify-center transition-all hover:-translate-y-0.5" aria-label="Facebook">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
          <a href="#" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-[#0A66C2] hover:bg-[#0958a7] flex items-center justify-center transition-all hover:-translate-y-0.5" aria-label="LinkedIn">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-[#25D366] hover:bg-[#20ba59] flex items-center justify-center transition-all hover:-translate-y-0.5" aria-label="WhatsApp">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <a href="#" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-[#2CA5E0] hover:bg-[#2694c9] flex items-center justify-center transition-all hover:-translate-y-0.5" aria-label="Telegram">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Navigation -->
      <div>
        <h4 class="text-sm font-semibold text-[var(--text-primary)] mb-4 uppercase tracking-wider">{t.footer.nav_title}</h4>
        <ul class="space-y-3">
          <li><a href={getLocalePath('/', locale)} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">{t.footer.home}</a></li>
          <li>
            <span class="text-sm text-[var(--text-secondary)]">{t.footer.services}</span>
            <ul class="mt-2 ml-3 space-y-2">
              <li><a href={getLocalePath('/insights/?domain=tech', locale)} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">{locale === 'zh' ? '科技情报' : 'Tech Intelligence'}</a></li>
              <li><a href={getLocalePath('/insights/?domain=ai', locale)} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">{locale === 'zh' ? 'AI 情报' : 'AI Intelligence'}</a></li>
              <li><a href={getLocalePath('/insights/?domain=finance', locale)} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">{locale === 'zh' ? '金融情报' : 'Finance Intelligence'}</a></li>
            </ul>
          </li>
          <li><a href={getLocalePath('/insights/', locale)} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">{locale === 'zh' ? '情报中心' : 'Intelligence Hub'}</a></li>
          <li><a href={getLocalePath('/contact/', locale)} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">{t.footer.contact}</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-semibold text-[var(--text-primary)] mb-4 uppercase tracking-wider">{t.footer.links_title}</h4>
        <ul class="space-y-3">
          <li><a href="https://www.transsion.com/" target="_blank" rel="noreferrer noopener" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">TRANSSION Holdings</a></li>
          <li><a href="https://www.huawei.com/" target="_blank" rel="noreferrer noopener" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Huawei</a></li>
          <li><a href="https://www.vivo.com/" target="_blank" rel="noreferrer noopener" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">vivo</a></li>
          <li><a href="https://www.mi.com/" target="_blank" rel="noreferrer noopener" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Xiaomi</a></li>
          <li><a href="https://guangdada.net/" target="_blank" rel="noreferrer noopener" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Guangdada</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[var(--text-muted)]">{t.footer.copyright}</p>
    </div>
  </div>
</footer>
