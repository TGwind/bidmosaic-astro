---
import { getLocalePath } from '@i18n/utils';
import type { Locale } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isZh = locale === 'zh';
---

<footer class="bg-[var(--bg-dark)] border-t border-white/5">
  <div class="container py-12">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
      <div>
        <h4 class="text-sm font-semibold text-[var(--text-primary)] mb-3 uppercase tracking-wider">
          {isZh ? 'BidMosaic' : 'BidMosaic'}
        </h4>
        <p class="text-sm leading-relaxed text-[var(--text-secondary)]">
          {isZh
            ? '聚焦广告合作、增长需求与资源匹配。先把真实合作机会接住，再逐步扩展系统能力。'
            : 'Focused on advertising partnerships, growth demand, and resource matching. Capture real opportunities first, then expand the system step by step.'}
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-[var(--text-primary)] mb-3 uppercase tracking-wider">
          {isZh ? '快速入口' : 'Quick Links'}
        </h4>
        <div class="flex flex-col gap-2 text-sm text-[var(--text-secondary)]">
          <a href={getLocalePath('/', locale)} class="hover:text-[var(--text-primary)] transition-colors">{isZh ? '首页' : 'Home'}</a>
          <a href={getLocalePath('/insights/', locale)} class="hover:text-[var(--text-primary)] transition-colors">{isZh ? '最新观察' : 'Insights'}</a>
          <a href={getLocalePath('/contact/', locale)} class="hover:text-[var(--text-primary)] transition-colors">{isZh ? '提交需求' : 'Submit Request'}</a>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-[var(--text-primary)] mb-3 uppercase tracking-wider">
          {isZh ? '联系与合作' : 'Contact & Partnership'}
        </h4>
        <p class="text-sm text-[var(--text-secondary)]">
          {isZh ? '如果你有广告合作、渠道对接或增长项目，直接提交需求，或者扫码加微信。' : 'If you have an advertising, channel, or growth project, submit your request directly or connect on WeChat.'}
        </p>
        <div class="bg-white rounded-xl p-3 inline-block mt-4">
          <img
            src="/images/个人微信.jpg"
            alt="WeChat QR Code"
            class="w-28 h-28 object-contain"
          />
        </div>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-white/5 flex justify-center">
      <p class="text-xs text-[var(--text-muted)]">Copyright © 2026 Bidmosaic</p>
    </div>
  </div>
</footer>
