---
interface Props {
  locale: 'zh' | 'en';
  compact?: boolean;
}

const { locale, compact = false } = Astro.props;
const isZh = locale === 'zh';

const copy = isZh
  ? {
      title: compact ? '提交需求，尽快聊清楚' : '告诉我你的需求，我来给你方案',
      subtitle: compact
        ? '先把项目背景、目标和联系方式留给我。'
        : '先收集最关键的业务信息，不做冗长表单。提交后会尽快联系你，确认合作方向、投放目标和资源匹配方式。',
      fields: {
        companyName: '公司 / 项目名',
        customerName: '联系人',
        contactInfo: '联系方式',
        bizType: '当前角色',
        summary: '当前需求',
        budget: '月预算 / 目标规模',
      },
      placeholders: {
        companyName: '例如：某出海 APP / 广告主团队 / 渠道项目',
        customerName: '怎么称呼你',
        contactInfo: '微信 / Telegram / 邮箱 / 手机号',
        summary: '例如：想找海外 APP 增长渠道、广告主资源、投放自动化方案',
        budget: '例如：3万美金/月，或先从小规模测试开始',
      },
      bizTypes: ['广告主', '渠道方 / 流量主', '代理 / 代投团队', '产品 / APP 团队', '其他'],
      submit: '提交需求',
      note: '原则是先沟通真实需求，再决定要不要继续投入时间和资源。',
      success: '已收到，我会尽快联系你。',
      error: '提交失败，请稍后再试。',
      network: '网络异常，请稍后重试。',
      required: '请至少填写「公司 / 项目名」或「联系人」，并留下联系方式。',
    }
  : {
      title: compact ? 'Share your request' : 'Tell me what you need, I will reply with a practical plan',
      subtitle: compact
        ? 'Leave the project context, goal, and a way to reach you.'
        : 'Collect only the business details that matter first. No long form. After submission, I can follow up on goals, channel fit, and possible cooperation next steps.',
      fields: {
        companyName: 'Company / Project',
        customerName: 'Contact Name',
        contactInfo: 'Contact Info',
        bizType: 'Your Role',
        summary: 'What do you need',
        budget: 'Monthly budget / target scale',
      },
      placeholders: {
        companyName: 'For example: app team, advertiser, channel project',
        customerName: 'How should I address you',
        contactInfo: 'Email / Telegram / WhatsApp / phone',
        summary: 'For example: growth channels, advertiser resources, campaign automation',
        budget: 'For example: $30k/month or test budget first',
      },
      bizTypes: ['Advertiser', 'Publisher / Traffic Owner', 'Agency', 'Product / App Team', 'Other'],
      submit: 'Submit',
      note: 'The rule is simple: clarify the real need first, then decide whether it is worth deeper effort.',
      success: 'Received. I will get back to you soon.',
      error: 'Submission failed. Please try again later.',
      network: 'Network error. Please retry later.',
      required: 'Please fill at least company/project or contact name, and leave a contact method.',
    };
---

<section class:list={[compact ? 'rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur' : 'rounded-[28px] border border-white/10 bg-[var(--bg-secondary)] p-6 shadow-[0_20px_60px_rgba(15,23,42,0.18)] sm:p-8']}>
  <div class="max-w-3xl">
    <h2 class="text-2xl font-bold text-[var(--text-primary)] sm:text-3xl">{copy.title}</h2>
    <p class="mt-3 text-sm leading-7 text-[var(--text-secondary)] sm:text-base">{copy.subtitle}</p>
  </div>

  <form id={`lead-form-${compact ? 'compact' : 'full'}`} class="mt-8 grid gap-4 md:grid-cols-2">
    <label class="block">
      <span class="mb-2 block text-sm font-medium text-[var(--text-secondary)]">{copy.fields.companyName}</span>
      <input name="companyName" type="text" placeholder={copy.placeholders.companyName} class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:border-cyan-500/50 focus:outline-none" />
    </label>

    <label class="block">
      <span class="mb-2 block text-sm font-medium text-[var(--text-secondary)]">{copy.fields.customerName}</span>
      <input name="customerName" type="text" placeholder={copy.placeholders.customerName} class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:border-cyan-500/50 focus:outline-none" />
    </label>

    <label class="block md:col-span-2">
      <span class="mb-2 block text-sm font-medium text-[var(--text-secondary)]">{copy.fields.contactInfo}</span>
      <input name="contactInfo" type="text" required placeholder={copy.placeholders.contactInfo} class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:border-cyan-500/50 focus:outline-none" />
    </label>

    <label class="block">
      <span class="mb-2 block text-sm font-medium text-[var(--text-secondary)]">{copy.fields.bizType}</span>
      <select name="bizType" class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-[var(--text-primary)] focus:border-cyan-500/50 focus:outline-none">
        <option value=""></option>
        {copy.bizTypes.map((item) => <option value={item}>{item}</option>)}
      </select>
    </label>

    <label class="block">
      <span class="mb-2 block text-sm font-medium text-[var(--text-secondary)]">{copy.fields.budget}</span>
      <input name="budget" type="text" placeholder={copy.placeholders.budget} class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:border-cyan-500/50 focus:outline-none" />
    </label>

    <label class="block md:col-span-2">
      <span class="mb-2 block text-sm font-medium text-[var(--text-secondary)]">{copy.fields.summary}</span>
      <textarea name="summary" rows="5" placeholder={copy.placeholders.summary} class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:border-cyan-500/50 focus:outline-none"></textarea>
    </label>

    <div class="md:col-span-2 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs leading-6 text-[var(--text-muted)]">{copy.note}</p>
      <button type="submit" class="btn btn-primary min-w-[160px] px-6 py-3">{copy.submit}</button>
    </div>

    <p id={`lead-form-msg-${compact ? 'compact' : 'full'}`} class="md:col-span-2 hidden text-sm" data-success={copy.success} data-error={copy.error} data-network={copy.network} data-required={copy.required}></p>
  </form>
</section>

<script define:vars={{ compact }} is:inline>
  const form = document.getElementById(`lead-form-${compact ? 'compact' : 'full'}`);
  const msg = document.getElementById(`lead-form-msg-${compact ? 'compact' : 'full'}`);

  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const payload = Object.fromEntries(data.entries());

      if ((!payload.companyName && !payload.customerName) || !payload.contactInfo) {
        msg.textContent = msg.dataset.required || 'Please complete the required fields.';
        msg.className = 'text-sm text-red-400';
        return;
      }

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ...payload,
            source: compact ? 'landing-compact-form' : 'landing-full-form',
          }),
        });

        if (res.ok) {
          msg.textContent = msg.dataset.success || 'Submitted successfully.';
          msg.className = 'text-sm text-green-400';
          form.reset();
        } else {
          const error = await res.json().catch(() => ({}));
          msg.textContent = error.error || msg.dataset.error || 'Submission failed.';
          msg.className = 'text-sm text-red-400';
        }
      } catch {
        msg.textContent = msg.dataset.network || 'Network error';
        msg.className = 'text-sm text-red-400';
      }
    });
  }
</script>
