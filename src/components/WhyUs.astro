---
import { useTranslations } from '@i18n/utils';
import type { Locale } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const features = [
  {
    title: t.why.ai_title,
    desc: t.why.ai_desc,
    icon: 'M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 14.5M14.25 3.104c.251.023.501.05.75.082M19.8 14.5l-2.303 2.303a2.25 2.25 0 01-1.838.668l-2.909-.33a2.25 2.25 0 00-2.5 2.5l.33 2.91a2.25 2.25 0 01-.668 1.837L7.5 26.8',
    color: 'blue',
  },
  {
    title: t.why.global_title,
    desc: t.why.global_desc,
    icon: 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418',
    color: 'cyan',
  },
  {
    title: t.why.data_title,
    desc: t.why.data_desc,
    icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
    color: 'purple',
  },
  {
    title: t.why.service_title,
    desc: t.why.service_desc,
    icon: 'M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z',
    color: 'amber',
  },
];

const colorClasses: Record<string, { bg: string; icon: string }> = {
  blue:   { bg: 'bg-blue-500/20', icon: 'text-blue-400' },
  cyan:   { bg: 'bg-cyan-500/20', icon: 'text-cyan-400' },
  purple: { bg: 'bg-purple-500/20', icon: 'text-purple-400' },
  amber:  { bg: 'bg-cyan-500/20', icon: 'text-cyan-400' },
};
---

<section class="section-dark py-24 relative overflow-hidden">
  <!-- Animated dot grid background -->
  <div class="why-dot-grid absolute inset-0 z-0 pointer-events-none" aria-hidden="true"></div>

  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[600px] h-[600px] pointer-events-none z-[1]" style="background: radial-gradient(circle, rgba(6,182,212,0.1) 0%, transparent 70%);" data-parallax="0.05"></div>

  <!-- Secondary floating glow -->
  <div class="absolute bottom-0 right-1/4 w-[300px] h-[300px] pointer-events-none z-[1]" style="background: radial-gradient(circle, rgba(59,130,246,0.05) 0%, transparent 70%);" data-parallax="-0.08" aria-hidden="true"></div>

  <!-- Floating connection lines -->
  <div class="why-connection-lines absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
    <svg class="w-full h-full" preserveAspectRatio="none">
      <line x1="10%" y1="20%" x2="30%" y2="40%" stroke="#06b6d4" stroke-width="0.5" opacity="0.08" class="why-line" />
      <line x1="70%" y1="15%" x2="90%" y2="45%" stroke="#3b82f6" stroke-width="0.5" opacity="0.06" class="why-line" style="animation-delay: 2s;" />
      <line x1="40%" y1="70%" x2="60%" y2="90%" stroke="#06b6d4" stroke-width="0.5" opacity="0.06" class="why-line" style="animation-delay: 4s;" />
    </svg>
  </div>

  <div class="container relative">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-[var(--text-primary)] mb-4" data-text-reveal>{t.why.section_title}</h2>
      <p class="text-[var(--text-secondary)] max-w-xl mx-auto">{t.why.section_subtitle}</p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto items-stretch" data-stagger-parent>
      {features.map((feature) => {
        const colors = colorClasses[feature.color];
        return (
          <div class="why-card glow-card p-7 flex items-start gap-5 h-full" data-stagger-child data-why-tilt>
            {/* Mouse glow */}
            <div class="why-card-glow" aria-hidden="true"></div>
            {/* Shine sweep */}
            <div class="why-card-shine" aria-hidden="true"></div>
            <div class={`why-icon self-start flex-shrink-0 w-11 h-11 rounded-xl ${colors.bg} flex items-center justify-center`}>
              <svg class={`w-5 h-5 ${colors.icon}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-[var(--text-primary)] mb-1.5">{feature.title}</h3>
              <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{feature.desc}</p>
            </div>
            {/* Hover border accent line */}
            <div class="why-card-line" aria-hidden="true"></div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .why-card {
    position: relative;
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.3s ease;
    perspective: 600px;
  }

  .why-card:hover {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
  }

  /* Mouse-follow glow */
  .why-card-glow {
    position: absolute;
    width: 250px;
    height: 250px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.12) 0%, transparent 70%);
    pointer-events: none;
    opacity: 0;
    transform: translate(-50%, -50%);
    transition: opacity 0.3s ease;
    z-index: 0;
  }

  .why-card:hover .why-card-glow {
    opacity: 1;
  }

  /* Shine sweep */
  .why-card-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.1) 45%, rgba(255,255,255,0.03) 50%, transparent 55%);
    pointer-events: none;
    z-index: 1;
  }

  .why-card:hover .why-card-shine {
    animation: why-shine-sweep 0.7s ease-in-out;
  }

  @keyframes why-shine-sweep {
    0% { left: -100%; }
    100% { left: 150%; }
  }

  /* Icon animation on hover */
  .why-icon {
    transition: transform 0.4s ease, box-shadow 0.3s ease;
  }

  .why-card:hover .why-icon {
    transform: scale(1.15) rotate(-5deg);
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.3);
  }

  /* Bottom accent line that expands on hover */
  .why-card-line {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, #06b6d4, transparent);
    transition: width 0.4s ease;
    pointer-events: none;
  }

  .why-card:hover .why-card-line {
    width: 80%;
  }

  /* Animated dot grid */
  .why-dot-grid {
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
    animation: dot-grid-drift 20s linear infinite;
  }

  @keyframes dot-grid-drift {
    from { background-position: 0 0; }
    to { background-position: 32px 32px; }
  }

  /* Connection lines */
  .why-line {
    animation: line-pulse 6s ease-in-out infinite;
  }

  @keyframes line-pulse {
    0%, 100% { opacity: 0.04; }
    50% { opacity: 0.12; }
  }

  @media (prefers-reduced-motion: reduce) {
    .why-card:hover { transform: none; }
    .why-card:hover .why-icon { transform: none; }
    .why-card-line { display: none; }
    .why-card-shine { display: none; }
    .why-card-glow { display: none; }
    .why-dot-grid { animation: none; }
    .why-line { animation: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-why-tilt]').forEach((card) => {
    const glow = card.querySelector<HTMLElement>('.why-card-glow');
    if (!glow) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;

      const rotateX = ((y - centerY) / centerY) * -5;
      const rotateY = ((x - centerX) / centerX) * 5;
      card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;

      glow.style.left = `${x}px`;
      glow.style.top = `${y}px`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  });
</script>
