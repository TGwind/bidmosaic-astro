---
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations, getLocalePath } from '@i18n/utils';
import { getCollection } from 'astro:content';

export const prerender = false;

const locale = 'en';
const t = useTranslations(locale);

const domainFilter = Astro.url.searchParams.get('domain') || '';
const perPage = 12;
const page = Math.max(1, Number(Astro.url.searchParams.get('page') || '1') || 1);

const all = (await getCollection('insights'))
  .filter((p) => p.data.status === 'published')
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const filtered = domainFilter ? all.filter((p) => p.data.domain === domainFilter) : all;
const pages = Math.max(1, Math.ceil(filtered.length / perPage));
const safePage = Math.min(pages, page);
const items = filtered.slice((safePage - 1) * perPage, safePage * perPage);

const domains = [
  { key: '', label: t.insights.all },
  { key: 'tech', label: t.insights.domain_tech },
  { key: 'ai', label: t.insights.domain_ai },
  { key: 'finance', label: t.insights.domain_finance },
  { key: 'ecommerce', label: t.insights.domain_ecommerce },
  { key: 'policy', label: t.insights.domain_policy },
  { key: 'crypto', label: t.insights.domain_crypto },
  { key: 'general', label: t.insights.domain_general },
];

const domainColors: Record<string, string> = {
  tech: 'bg-blue-500/20 text-blue-400',
  ai: 'bg-purple-500/20 text-purple-400',
  finance: 'bg-green-500/20 text-green-400',
  ecommerce: 'bg-orange-500/20 text-orange-400',
  policy: 'bg-red-500/20 text-red-400',
  crypto: 'bg-yellow-500/20 text-yellow-400',
  general: 'bg-gray-500/20 text-gray-400',
};

const toSlug = (item: (typeof items)[number]) =>
  item.id.replace(/^.*\//, '').replace(/\/index$/, '');

const buildUrl = (params: Record<string, string>) => {
  const base = getLocalePath('/insights/', locale);
  const qs = new URLSearchParams(params).toString();
  return qs ? `${base}?${qs}` : base;
};
---

<BaseLayout
  title={t.insights.page_title}
  description={t.insights.page_subtitle}
  locale={locale}
>
  <section class="pt-32 pb-24" style="background: var(--bg-primary);">
    <div class="container">
      <!-- Header -->
      <div class="text-center mb-12" data-animate>
        <h1 class="text-4xl sm:text-5xl font-bold text-[var(--text-primary)] mb-4">
          {t.insights.page_title}
        </h1>
        <p class="text-lg text-[var(--text-secondary)] max-w-xl mx-auto">
          {t.insights.page_subtitle}
        </p>
      </div>

      <!-- Domain Filter -->
      <div class="flex flex-wrap justify-center gap-2 mb-12" data-animate>
        {domains.map((d) => (
          <a
            href={buildUrl(d.key ? { domain: d.key } : {})}
            class:list={[
              'px-4 py-2 rounded-full text-sm font-medium transition-all duration-200',
              domainFilter === d.key
                ? 'bg-cyan-500 text-white border border-cyan-500'
                : 'bg-white/5 text-[var(--text-secondary)] border border-white/10 hover:border-cyan-500/50 hover:text-[var(--text-primary)]',
            ]}
          >
            {d.label}
          </a>
        ))}
      </div>

      <!-- Items Grid -->
      {items.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto" data-stagger-parent>
          {items.map((item) => (
            <a
              href={`/insights/${toSlug(item)}/`}
              class="glow-card group overflow-hidden flex flex-col h-full"
              data-stagger-child
            >
              <div class="p-6 flex flex-col flex-1">
                <!-- Top: Domain + Tier + Importance -->
                <div class="flex items-center gap-2 mb-3">
                  <span class:list={['text-xs font-medium px-2.5 py-0.5 rounded-full', domainColors[item.data.domain] || domainColors.general]}>
                    {domains.find((d) => d.key === item.data.domain)?.label || item.data.domain}
                  </span>
                  {item.data.tier === 'pro' && (
                    <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-cyan-500/20 text-cyan-400">
                      PRO
                    </span>
                  )}
                  <span class="ml-auto flex items-center gap-1 text-xs text-[var(--text-muted)]">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    {item.data.importance}
                  </span>
                </div>

                <!-- Title -->
                <h2 class="text-lg font-bold text-[var(--text-primary)] mb-2 group-hover:text-cyan-400 transition-colors insight-title-clamp">
                  {item.data.title}
                </h2>

                <!-- Summary -->
                <p class="text-sm text-[var(--text-secondary)] leading-relaxed mb-4 flex-1 insight-desc-clamp">
                  {item.data.summary}
                </p>

                <!-- Tags -->
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {item.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="text-xs px-2 py-0.5 rounded bg-white/8 text-[var(--text-secondary)]">
                      {tag}
                    </span>
                  ))}
                </div>

                <!-- Footer -->
                <div class="flex items-center justify-between text-xs text-[var(--text-muted)] mt-auto pt-3 border-t border-[var(--text-muted)]/10">
                  <time datetime={item.data.publishedAt}>
                    {new Date(item.data.publishedAt).toLocaleDateString(locale === 'zh' ? 'zh-CN' : 'en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                  {item.data.source && (
                    <span class="truncate ml-2">{item.data.source}</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-[var(--text-muted)]">
          <p class="text-lg">{t.insights.no_items}</p>
        </div>
      )}

      <!-- Pagination -->
      {pages > 1 && (
        <div class="flex items-center justify-center gap-3 mt-12 text-sm text-[var(--text-secondary)]">
          <a
            class="px-3 py-2 rounded-md border border-[var(--text-muted)]/20 hover:border-[var(--text-muted)]/40 transition-colors"
            href={buildUrl({ ...(domainFilter ? { domain: domainFilter } : {}), page: String(Math.max(1, safePage - 1)) })}
            aria-disabled={safePage <= 1}
          >
            &larr;
          </a>
          <span class="text-[var(--text-muted)]">{safePage} / {pages}</span>
          <a
            class="px-3 py-2 rounded-md border border-[var(--text-muted)]/20 hover:border-[var(--text-muted)]/40 transition-colors"
            href={buildUrl({ ...(domainFilter ? { domain: domainFilter } : {}), page: String(Math.min(pages, safePage + 1)) })}
            aria-disabled={safePage >= pages}
          >
            &rarr;
          </a>
        </div>
      )}

      <!-- Subscribe CTA -->
      <div class="mt-16 max-w-xl mx-auto text-center" data-animate>
        <div class="glow-card p-8">
          <h3 class="text-xl font-bold text-[var(--text-primary)] mb-2">{t.insights.subscribe_title}</h3>
          <p class="text-sm text-[var(--text-secondary)] mb-4">{t.insights.subscribe_desc}</p>
          <form id="subscribe-form" class="flex gap-2">
            <input
              type="email"
              name="email"
              required
              placeholder={t.insights.subscribe_placeholder}
              class="flex-1 px-4 py-2.5 rounded-lg border border-white/10 bg-[var(--bg-card)] text-sm text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:border-cyan-500/40"
            />
            <button type="submit" class="btn btn-primary text-sm px-6 py-2.5">
              {t.insights.subscribe_btn}
            </button>
          </form>
          <p id="subscribe-msg" class="text-sm mt-3 hidden"></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .insight-title-clamp {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }
  .insight-desc-clamp {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
  }
</style>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const msg = document.getElementById('subscribe-msg');
  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = new FormData(form).get('email') as string;
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (res.ok) {
          msg.textContent = 'Subscribed!';
          msg.className = 'text-sm mt-3 text-green-600';
          form.reset();
        } else {
          const data = await res.json().catch(() => ({}));
          msg.textContent = data.error || 'Failed to subscribe';
          msg.className = 'text-sm mt-3 text-red-600';
        }
      } catch {
        msg.textContent = 'Network error, please retry';
        msg.className = 'text-sm mt-3 text-red-600';
      }
    });
  }
</script>
