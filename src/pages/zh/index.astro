---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Products from '@components/Products.astro';
import BusinessModules from '@components/BusinessModules.astro';
import WhyUs from '@components/WhyUs.astro';
import Cases from '@components/Cases.astro';
import About from '@components/About.astro';
import CtaSection from '@components/CtaSection.astro';
import SectionDivider from '@components/SectionDivider.astro';

const locale = 'zh';
---

<BaseLayout title="AI 驱动的效果型程序化增长平台" locale={locale}>
  <Hero locale={locale} />
  <Products locale={locale} />
  <BusinessModules locale={locale} />
  <SectionDivider from="secondary" to="primary" variant="wave" />
  <WhyUs locale={locale} />
  <SectionDivider from="primary" to="secondary" variant="tilt" />
  <Cases locale={locale} />
  <SectionDivider from="secondary" to="primary" variant="curve" />
  <About locale={locale} />
  <CtaSection locale={locale} />
</BaseLayout>
