---
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations, getLocalePath } from '@i18n/utils';
import { getCollection, render } from 'astro:content';

export const prerender = false;

const locale = 'zh';
const t = useTranslations(locale);
const slug = String(Astro.params.slug || '');

const all = (await getCollection('insights'))
  .filter((p) => p.data.status === 'published')
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const toSlug = (item: (typeof all)[number]) =>
  item.id.replace(/^.*\//, '').replace(/\/index$/, '');

const idx = all.findIndex((p) => toSlug(p) === slug);
const entry = idx >= 0 ? all[idx] : null;
const prevEntry = idx > 0 ? all[idx - 1] : null;
const nextEntry = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;

let Content: any = null;
if (entry) {
  const rendered = await render(entry as any);
  Content = rendered.Content;
}

if (!entry) Astro.response.status = 404;

const domainLabels: Record<string, string> = {
  tech: t.insights.domain_tech,
  ai: t.insights.domain_ai,
  finance: t.insights.domain_finance,
  ecommerce: t.insights.domain_ecommerce,
  policy: t.insights.domain_policy,
  crypto: t.insights.domain_crypto,
  general: t.insights.domain_general,
};

const domainColors: Record<string, string> = {
  tech: 'bg-blue-100 text-blue-700',
  ai: 'bg-purple-100 text-purple-700',
  finance: 'bg-green-100 text-green-700',
  ecommerce: 'bg-orange-100 text-orange-700',
  policy: 'bg-red-100 text-red-700',
  crypto: 'bg-yellow-100 text-yellow-800',
  general: 'bg-gray-100 text-gray-700',
};

const related = entry
  ? all.filter((p) => p.data.domain === entry.data.domain && toSlug(p) !== slug).slice(0, 3)
  : [];
---

{entry ? (
  <BaseLayout title={entry.data.title} description={entry.data.summary} locale={locale}>
    <article class="pt-32 pb-24" style="background: var(--bg-secondary);">
      <div class="container max-w-3xl">
        <!-- Back -->
        <a
          href={getLocalePath('/insights/', locale)}
          class="inline-flex items-center gap-1.5 text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors mb-8"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          {t.insights.back}
        </a>

        <!-- Header -->
        <header class="mb-12" data-animate>
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class:list={['text-xs font-medium px-2.5 py-0.5 rounded-full', domainColors[entry.data.domain] || domainColors.general]}>
              {domainLabels[entry.data.domain] || entry.data.domain}
            </span>
            {entry.data.tier === 'pro' && (
              <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-[var(--bg-dark)] text-[var(--bg-primary)]">
                PRO
              </span>
            )}
            <span class="flex items-center gap-1 text-xs text-[var(--text-muted)]">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
              {t.insights.importance}: {entry.data.importance}/10
            </span>
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--text-primary)] leading-tight mb-4">
            {entry.data.title}
          </h1>

          <p class="text-lg text-[var(--text-secondary)] mb-4">{entry.data.summary}</p>

          <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--text-muted)]">
            <time datetime={entry.data.publishedAt}>
              {new Date(entry.data.publishedAt).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {entry.data.source && (
              <>
                <span>&middot;</span>
                {entry.data.sourceUrl ? (
                  <a href={entry.data.sourceUrl} target="_blank" rel="noopener" class="hover:text-[var(--text-primary)] transition-colors">
                    {t.insights.source}: {entry.data.source}
                  </a>
                ) : (
                  <span>{t.insights.source}: {entry.data.source}</span>
                )}
              </>
            )}
          </div>

          <div class="flex flex-wrap gap-2 mt-4">
            {entry.data.tags.map((tag: string) => (
              <span class="text-xs px-2.5 py-0.5 rounded-full bg-[var(--bg-primary)] text-[var(--text-secondary)]">
                {tag}
              </span>
            ))}
          </div>
        </header>

        <!-- Content -->
        <div class="article-content prose prose-lg max-w-none" lang="zh" data-animate>
          {Content ? <Content /> : null}
        </div>

        <!-- Prev/Next -->
        <nav class="mt-16 pt-8 border-t border-[var(--text-muted)]/10 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {prevEntry && (
            <a href={`/zh/insights/${toSlug(prevEntry)}/`} class="glow-card p-5 group">
              <span class="text-xs text-[var(--text-muted)] mb-1 block">{t.insights.prev}</span>
              <span class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[#e6b800] transition-colors line-clamp-2">
                {prevEntry.data.title}
              </span>
            </a>
          )}
          {nextEntry && (
            <a href={`/zh/insights/${toSlug(nextEntry)}/`} class="glow-card p-5 group text-right sm:col-start-2">
              <span class="text-xs text-[var(--text-muted)] mb-1 block">{t.insights.next}</span>
              <span class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[#e6b800] transition-colors line-clamp-2">
                {nextEntry.data.title}
              </span>
            </a>
          )}
        </nav>

        <!-- Related -->
        {related.length > 0 && (
          <section class="mt-16">
            <h3 class="text-xl font-bold text-[var(--text-primary)] mb-6">{t.insights.related}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {related.map((item) => (
                <a href={`/zh/insights/${toSlug(item)}/`} class="glow-card p-4 group">
                  <span class:list={['text-xs font-medium px-2 py-0.5 rounded-full inline-block mb-2', domainColors[item.data.domain] || domainColors.general]}>
                    {domainLabels[item.data.domain] || item.data.domain}
                  </span>
                  <h4 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[#e6b800] transition-colors line-clamp-2">
                    {item.data.title}
                  </h4>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </article>
  </BaseLayout>
) : (
  <BaseLayout title="未找到" description="情报未找到" locale={locale}>
    <section class="pt-32 pb-24" style="background: var(--bg-secondary);">
      <div class="container max-w-3xl">
        <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-3">情报未找到</h1>
        <a class="text-sm text-[var(--text-secondary)] underline" href="/zh/insights/">{t.insights.back}</a>
      </div>
    </section>
  </BaseLayout>
)}
